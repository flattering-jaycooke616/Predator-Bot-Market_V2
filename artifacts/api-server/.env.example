# API Server Environment Variables
# Copy this file to .env and fill in the values

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/predator_bots

# Clerk Authentication
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Google Cloud Storage (choose one method)
# Option 1: Service account key file path
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Option 2: Individual credentials
# GCS_PROJECT_ID=your-project-id
# GCS_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# GCS_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# Object Storage Paths
PUBLIC_OBJECT_SEARCH_PATHS=bucket-name/public,bucket-name/assets
PRIVATE_OBJECT_DIR=bucket-name/private

# Server
PORT=8080
NODE_ENV=development
LOG_LEVEL=info
